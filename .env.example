# WikiDelve Configuration
# Copy to .env and fill in your keys

# Search API (required for research)
SERPER_API_KEY=your_serper_api_key

# --- LLM Provider -----------------------------------------------------------
# Choose: "minimax" (default) or "bedrock"
# LLM_PROVIDER=minimax

# --- Option A: Minimax (default) --------------------------------------------
MINIMAX_API_KEY=your_minimax_api_key

# --- Option B: AWS Bedrock --------------------------------------------------
# LLM_PROVIDER=bedrock
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
# BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
#
# Auth option 1: Explicit credentials
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_SESSION_TOKEN=optional_session_token
#
# Auth option 2: IAM role (no keys needed — works on EC2, ECS, EKS, Lambda)
# Just set LLM_PROVIDER=bedrock and BEDROCK_REGION, boto3 handles the rest.
#
# Auth option 3: AWS CLI profile
# AWS_PROFILE=your_profile_name

# Optional: Secondary search provider
TAVILY_API_KEY=your_tavily_api_key

# --- Database Backend --------------------------------------------------------
# "sqlite" (default) or "dynamodb"
# DB_BACKEND=sqlite
#
# DynamoDB settings (only needed if DB_BACKEND=dynamodb):
# DB_DYNAMO_TABLE=wikidelve
# DB_DYNAMO_ENDPOINT=http://localhost:8000  # optional, for local DynamoDB

# --- S3 Backing Store (optional) --------------------------------------------
# When set, all wiki articles, research files, and DB are mirrored to S3.
# Uses the same AWS credentials configured above for Bedrock.
# S3_BUCKET=my-wikidelve-backup
# S3_PREFIX=wikidelve

# --- Local Research Watches (optional, runs daily via cron) ------------------
# JSON array of paths to scan periodically. No search API keys needed.
# LOCAL_RESEARCH_WATCHES=[{"topic":"my infra","path":"/code/infra","pattern":"*.tf"},{"topic":"backend api","path":"/code/api"}]

# --- Allowed Hosts -----------------------------------------------------------
# Comma-separated Host header allowlist. Defaults cover localhost + the
# docker-compose internal hostnames. For a Tailscale or public deploy, add
# your own hostnames, e.g.:
# ALLOWED_HOSTS=wikidelve.<your-tailnet>.ts.net,*.<your-tailnet>.ts.net,localhost,127.0.0.1,kb-service,wikidelve
